{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MouseFly",
  "version": "0.1.0",
  "identifier": "io.mousefly.app",
  "build": {
    "beforeDevCommand": "pnpm --dir ../../src-ui dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir ../../src-ui build",
    "frontendDist": "../../src-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MouseFly",
        "width": 480,
        "height": 320,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ]
  }
}

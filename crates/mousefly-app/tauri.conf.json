{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MouseFly",
  "version": "0.1.0",
  "identifier": "io.mousefly.app",
  "build": {
    "beforeDevCommand": "pnpm --filter mousefly-ui dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --filter mousefly-ui build",
    "frontendDist": "../../src-ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "MouseFly",
        "width": 480,
        "height": 480,
        "minWidth": 420,
        "minHeight": 460,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "nsis"],
    "category": "Utility",
    "shortDescription": "Keyboard and mouse forwarding across LAN hosts",
    "longDescription": "MouseFly lets one keyboard and mouse drive multiple computers across a LAN — like macOS Universal Control, but Windows ↔ macOS.",
    "copyright": "Copyright (c) 2026 MouseFly contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
